# DigitalOcean Droplet / Docker Compose example
#
# App code and deployment files live under:
#   /opt/openclaw
#
# Persistent data lives under:
#   /data/openclaw

OPENCLAW_IMAGE=openclaw:local
OPENCLAW_HOST_DATA_ROOT=/data/openclaw

OPENCLAW_STATE_DIR=/home/node/.openclaw
OPENCLAW_CONFIG_PATH=/home/node/.openclaw/openclaw.json
OPENCLAW_WORKSPACE_DIR=/home/node/.openclaw/workspace
OPENCLAW_LOG_DIR=/home/node/.openclaw/logs
CLAWDBOT_STATE_DIR=/home/node/.openclaw
MOLTBOT_STATE_DIR=/home/node/.openclaw
RSS_STATE_PATH=/home/node/.openclaw/state/etsy_rss.json

OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_GATEWAY_PUBLISH_HOST=0.0.0.0
OPENCLAW_GATEWAY_TOKEN=replace-with-a-long-random-token

MISSION_CONTROL_HOST=0.0.0.0
MISSION_CONTROL_PORT=3021
MISSION_CONTROL_PUBLISH_HOST=127.0.0.1
OPENCLAW_MISSION_CONTROL_CONFIG_PATH=/home/node/.openclaw/openclaw.json
OPENCLAW_MISSION_CONTROL_GATEWAY_URL=ws://openclaw-gateway:18789
OPENCLAW_MISSION_CONTROL_GATEWAY_TOKEN=replace-with-the-same-gateway-token

# Optional helper for the prepare-droplet script.
OPENCLAW_AGENT_WORKSPACES=jannetje,beppie,cornelis
