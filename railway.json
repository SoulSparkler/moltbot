{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "NODE_ENV=development pnpm install --frozen-lockfile",
    "env": {
      "NODE_VERSION": "22"
    }
  },
  "deploy": {
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "startCommand": "node_modules/.bin/tsx apps/etsy-auto-post/src/index.ts",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 100,
    "healthcheckInterval": 15
  },
  "volumes": [
    {
      "mountPath": "/data",
      "sizeGB": 1
    }
  ]
}
